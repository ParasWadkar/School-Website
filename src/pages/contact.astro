---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us"
  description="Contact H.S.R.D Public School in Lauriya, West Champaran, Bihar. Phone: 8210853223. Email: infohsrdgroupofinst53@gmail.com."
>
  <!-- Page hero -->
  <section class="bg-brand-blue py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-blue-300 text-sm mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-white" aria-current="page">Contact Us</li>
        </ol>
      </nav>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">Contact Us</h1>
      <p class="text-blue-200 mt-3 text-lg">We'd love to hear from you. Reach out for admissions, general enquiries, or directions.</p>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">

        <!-- Contact info + map -->
        <div>
          <h2 class="text-2xl font-extrabold text-gray-900 mb-6">Get in Touch</h2>
          <ul class="space-y-5 mb-8">
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-blue text-white rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Address</p>
                <p class="text-gray-600 text-sm mt-0.5">H.S.R.D Public School<br />Lauriya, West Champaran<br />Bihar, India</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-blue text-white rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21L8.5 10.5a11.042 11.042 0 005 5l1.113-1.724a1 1 0 011.21-.502l4.493 1.498A1 1 0 0121 15.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Phone</p>
                <a href="tel:8210853223" class="text-brand-blue hover:underline text-sm mt-0.5 block">8210853223</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-blue text-white rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Email</p>
                <a href="mailto:infohsrdgroupofinst53@gmail.com" class="text-brand-blue hover:underline text-sm mt-0.5 block break-all">
                  infohsrdgroupofinst53@gmail.com
                </a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-blue text-white rounded-lg flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Office Hours</p>
                <p class="text-gray-600 text-sm mt-0.5">Monday – Saturday: 8:00 AM – 4:00 PM<br />Sunday: Closed</p>
              </div>
            </li>
          </ul>

          <!-- Map embed -->
          <div class="rounded-xl overflow-hidden border border-gray-200 h-64">
            <iframe
              title="H.S.R.D Public School location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3563.0!2d84.3!3d27.0!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sLauriya%2C+West+Champaran%2C+Bihar!5e0!3m2!1sen!2sin!4v1700000000000"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <p class="text-xs text-gray-400 mt-2">Map shows Lauriya, West Champaran. Exact pin to be updated once confirmed.</p>
        </div>

        <!-- Contact form -->
        <div>
          <h2 class="text-2xl font-extrabold text-gray-900 mb-6">Send Us a Message</h2>
          <form
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            class="space-y-5"
          >
            <div>
              <label for="c-name" class="block text-sm font-semibold text-gray-700 mb-1.5">Your Name <span class="text-brand-red">*</span></label>
              <input type="text" id="c-name" name="name" required autocomplete="name"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent"
                placeholder="Full name" />
            </div>
            <div>
              <label for="c-phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Phone <span class="text-brand-red">*</span></label>
              <input type="tel" id="c-phone" name="phone" required autocomplete="tel"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent"
                placeholder="Your phone number" />
            </div>
            <div>
              <label for="c-email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
              <input type="email" id="c-email" name="email" autocomplete="email"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent"
                placeholder="Optional" />
            </div>
            <div>
              <label for="c-message" class="block text-sm font-semibold text-gray-700 mb-1.5">Message <span class="text-brand-red">*</span></label>
              <textarea id="c-message" name="message" required rows="5"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent resize-none"
                placeholder="How can we help you?"></textarea>
            </div>
            <input type="hidden" name="_subject" value="New Contact Message – H.S.R.D Public School" />
            <button type="submit"
              class="w-full bg-brand-blue hover:bg-brand-blue-light text-white font-bold py-3.5 px-6 rounded-lg transition-colors text-base">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick admission CTA -->
  <section class="bg-brand-yellow py-12">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-extrabold text-brand-blue mb-3">Interested in Admissions?</h2>
      <p class="text-brand-blue/80 mb-6">Use our dedicated admissions enquiry form for the fastest response.</p>
      <a href="/admissions#enquiry-form" class="inline-block bg-brand-blue hover:bg-brand-blue-light text-white font-bold px-8 py-4 rounded-lg transition-colors">
        Go to Enquiry Form
      </a>
    </div>
  </section>
</Layout>
