---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Us"
  description="Learn about H.S.R.D Public School – our history, vision, mission, leadership, and infrastructure in Lauriya, West Champaran, Bihar."
>
  <!-- Page hero -->
  <section class="bg-brand-blue py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-blue-300 text-sm mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-white" aria-current="page">About Us</li>
        </ol>
      </nav>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">About H.S.R.D Public School</h1>
      <p class="text-blue-200 mt-3 text-lg max-w-2xl">Building bright futures for the children of Lauriya and West Champaran since our founding.</p>
    </div>
  </section>

  <!-- Vision & Mission -->
  <section class="py-16 sm:py-20 bg-white" aria-labelledby="vision-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 id="vision-heading" class="text-3xl font-extrabold text-gray-900 mb-6">Our Vision & Mission</h2>

          <div class="mb-8 p-6 bg-brand-blue/5 border-l-4 border-brand-blue rounded-r-xl">
            <h3 class="font-bold text-brand-blue text-lg mb-2">Vision</h3>
            <p class="text-gray-700 leading-relaxed">
              To be the most trusted educational institution in West Champaran — where every child discovers their potential, builds strong character, and is prepared to thrive in a changing world.
            </p>
          </div>

          <div class="mb-8 p-6 bg-brand-red/5 border-l-4 border-brand-red rounded-r-xl">
            <h3 class="font-bold text-brand-red text-lg mb-2">Mission</h3>
            <p class="text-gray-700 leading-relaxed">
              To provide quality K–12 education through experienced teachers, regular assessment, and a caring environment that nurtures academic excellence, discipline, and holistic development.
            </p>
          </div>

          <div class="p-6 bg-brand-yellow/10 border-l-4 border-brand-yellow rounded-r-xl">
            <h3 class="font-bold text-yellow-700 text-lg mb-2">Our Motto</h3>
            <p class="text-gray-700 text-xl font-semibold italic">"Aspiring for Excellence"</p>
          </div>
        </div>

        <div>
          <h2 class="text-3xl font-extrabold text-gray-900 mb-6">Our Story</h2>
          <div class="prose prose-gray max-w-none">
            <p class="text-gray-600 leading-relaxed mb-4">
              H.S.R.D Public School was established with a single purpose: to bring high-quality education to the children of Lauriya, West Champaran. In a region where access to good schooling has historically been limited, our school has grown into a beacon of opportunity.
            </p>
            <p class="text-gray-600 leading-relaxed mb-4">
              Founded by <strong>Ashok Kumar</strong>, the school offers education from Nursery / Playgroup through Class XII. We are part of the H.S.R.D Group of Institutions, but our school is exclusively focused on K–12 students.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Our distinguishing features — monthly tests, a school van facility, and a genuinely lovely atmosphere — reflect our belief that every child deserves structure, safety, and joy in their learning journey.
            </p>
          </div>

          <!-- Board affiliation placeholder -->
          <div class="mt-8 p-5 bg-gray-50 rounded-xl border border-gray-200">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Board Affiliation</p>
            <p class="text-gray-700 font-semibold text-lg"><!-- TODO: Add board name and registration number --><span class="text-gray-400 italic text-base font-normal">Board affiliation to be confirmed</span></p>
            <p class="text-gray-400 text-sm mt-1">Affiliation / Registration No: <span class="italic">to be updated</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="py-16 sm:py-20 bg-gray-50" aria-labelledby="leadership-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="leadership-heading" class="text-3xl font-extrabold text-gray-900">Leadership</h2>
      </div>
      <div class="max-w-sm mx-auto">
        <article class="bg-white rounded-2xl overflow-hidden shadow-md border border-gray-100 text-center p-8">
          <div class="w-20 h-20 bg-brand-blue/10 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
            👨‍💼
          </div>
          <h3 class="font-bold text-gray-900 text-xl">Ashok Kumar</h3>
          <p class="text-brand-blue font-medium text-sm mt-1">Founder & Managing Director</p>
          <p class="text-gray-500 text-sm mt-3 leading-relaxed">
            Ashok Kumar founded H.S.R.D Group of Institutions with a vision to make quality education accessible to all children in West Champaran, Bihar.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Infrastructure -->
  <section class="py-16 sm:py-20 bg-white" aria-labelledby="infra-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="infra-heading" class="text-3xl font-extrabold text-gray-900">Our Infrastructure</h2>
        <p class="text-gray-500 mt-2 max-w-xl mx-auto">A safe and well-equipped campus designed to support learning at every level.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '🏫', title: 'Well-Equipped Classrooms', desc: 'Bright, spacious classrooms with proper seating, ventilation, and teaching aids.' },
          { icon: '📖', title: 'Library', desc: 'A stocked library with textbooks, reference books, and reading material for all levels.' },
          { icon: '🚐', title: 'School Van', desc: 'Safe, reliable transport facility covering Lauriya and surrounding areas.' },
          { icon: '🏃', title: 'Sports Ground', desc: 'Open grounds for physical education, sports, and outdoor activities.' },
          { icon: '🔬', title: 'Science Lab', desc: 'Hands-on science laboratory supporting practical learning for secondary students.' },
          { icon: '💻', title: 'Computer Lab', desc: 'Computer education integrated from primary level to prepare students for the digital age.' },
        ].map(({ icon, title, desc }) => (
          <article class="p-6 bg-gray-50 rounded-xl hover:bg-white hover:shadow-md border border-transparent hover:border-gray-200 transition-all">
            <div class="text-3xl mb-3">{icon}</div>
            <h3 class="font-bold text-gray-900 mb-1">{title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-blue py-14">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-extrabold text-white mb-4">Come See the School</h2>
      <p class="text-blue-200 mb-8">Visit our campus in Lauriya or get in touch — we'd love to tell you more about what we offer your child.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/admissions#enquiry-form" class="bg-brand-yellow hover:bg-yellow-400 text-brand-blue font-bold px-8 py-4 rounded-lg transition-all hover:scale-105">
          Enquire for Admission
        </a>
        <a href="/contact" class="bg-white/10 hover:bg-white/20 border border-white/30 text-white font-semibold px-8 py-4 rounded-lg transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
