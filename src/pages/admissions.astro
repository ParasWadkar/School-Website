---
import Layout from '../layouts/Layout.astro';

const steps = [
  { n: '01', title: 'Submit Enquiry', desc: 'Fill in the enquiry form below with your child\'s details. Our team will contact you within 24 hours.' },
  { n: '02', title: 'Visit the School', desc: 'Come meet the staff, see the facilities, and get a feel for the campus and learning environment.' },
  { n: '03', title: 'Collect Form', desc: 'Collect the official admission form from the school office. Bring required documents (listed below).' },
  { n: '04', title: 'Submit & Pay', desc: 'Submit the completed form along with documents and the admission fee at the school office.' },
  { n: '05', title: 'Confirmation', desc: 'Receive your child\'s admission confirmation, class allocation, and timetable.' },
];

const eligibility = [
  { stage: 'Nursery / LKG', age: '3 – 4 years' },
  { stage: 'UKG', age: '4 – 5 years' },
  { stage: 'Class I', age: '5 – 6 years' },
  { stage: 'Class II – XII', age: 'Age-appropriate, subject to availability' },
];

const documents = [
  'Birth certificate of the child',
  'Previous school transfer/leaving certificate (for Class II and above)',
  'Last year\'s report card / marksheet',
  'Aadhar card of child and parent/guardian',
  'Passport-size photographs (4 copies)',
  'Address proof of parent/guardian',
];
---

<Layout
  title="Admissions"
  description="H.S.R.D Public School admissions – process, eligibility, fee structure, and enquiry form. Admissions open for 2025–26 in Lauriya, West Champaran."
>
  <!-- Page hero -->
  <section class="bg-brand-blue py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-blue-300 text-sm mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-white">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-white" aria-current="page">Admissions</li>
        </ol>
      </nav>
      <div class="flex flex-wrap items-center gap-4">
        <div>
          <span class="inline-flex items-center gap-1.5 bg-brand-yellow text-brand-blue text-xs font-bold px-3 py-1 rounded-full mb-3">
            <span class="w-1.5 h-1.5 bg-brand-blue rounded-full animate-pulse"></span>
            Admissions Open 2025–26
          </span>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-white">Admissions</h1>
          <p class="text-blue-200 mt-3 text-lg max-w-2xl">Everything you need to know about joining H.S.R.D Public School.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 sm:py-20 bg-white" aria-labelledby="process-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="process-heading" class="text-3xl font-extrabold text-gray-900">Admission Process</h2>
        <p class="text-gray-500 mt-2">Simple steps to secure your child's place at H.S.R.D Public School</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {steps.map((step, i) => (
          <div class="relative">
            {i < steps.length - 1 && (
              <div class="hidden lg:block absolute top-8 left-full w-full h-0.5 bg-gray-200 z-0"></div>
            )}
            <div class="relative z-10 text-center p-4">
              <div class="w-16 h-16 bg-brand-blue text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4 shadow-md">
                {step.n}
              </div>
              <h3 class="font-bold text-gray-900 mb-2">{step.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Eligibility + Documents side by side -->
  <section class="py-16 sm:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10">

        <!-- Eligibility -->
        <div>
          <h2 class="text-2xl font-extrabold text-gray-900 mb-6">Age Eligibility</h2>
          <div class="overflow-hidden rounded-xl border border-gray-200">
            <table class="w-full text-sm">
              <thead class="bg-brand-blue text-white">
                <tr>
                  <th class="px-4 py-3 text-left font-semibold">Class / Stage</th>
                  <th class="px-4 py-3 text-left font-semibold">Age Requirement</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 bg-white">
                {eligibility.map(({ stage, age }) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium text-gray-900">{stage}</td>
                    <td class="px-4 py-3 text-gray-600">{age}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Documents required -->
        <div>
          <h2 class="text-2xl font-extrabold text-gray-900 mb-6">Documents Required</h2>
          <ul class="space-y-3">
            {documents.map((doc) => (
              <li class="flex items-start gap-3 bg-white p-4 rounded-xl border border-gray-200">
                <svg class="w-5 h-5 text-brand-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-gray-700 text-sm">{doc}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Fee structure -->
  <section class="py-16 sm:py-20 bg-white" aria-labelledby="fees-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="fees-heading" class="text-2xl font-extrabold text-gray-900 mb-6">Fee Structure</h2>
      <div class="bg-gray-50 rounded-2xl border-2 border-dashed border-gray-200 p-10 text-center">
        <p class="text-3xl mb-3">💰</p>
        <p class="text-gray-700 font-semibold mb-2">Fee details available on request</p>
        <p class="text-gray-400 text-sm mb-6">Contact us directly or fill in the enquiry form and we'll share the complete fee structure for your child's class.</p>
        <a href="#enquiry-form" class="inline-block bg-brand-blue hover:bg-brand-blue-light text-white font-semibold px-6 py-3 rounded-lg transition-colors">
          Request Fee Details
        </a>
      </div>
    </div>
  </section>

  <!-- Enquiry Form -->
  <section id="enquiry-form" class="py-16 sm:py-20 bg-brand-blue" aria-labelledby="form-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h2 id="form-heading" class="text-3xl font-extrabold text-white">Enquire for Admission</h2>
        <p class="text-blue-200 mt-2">Fill in the form below and we'll get back to you within 24 hours.</p>
      </div>

      <form
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        class="bg-white rounded-2xl p-6 sm:p-8 shadow-2xl space-y-5"
        novalidate
      >
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="child-name" class="block text-sm font-semibold text-gray-700 mb-1.5">Child's Name <span class="text-brand-red">*</span></label>
            <input type="text" id="child-name" name="child_name" required autocomplete="name"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition-shadow"
              placeholder="Enter child's full name" />
          </div>
          <div>
            <label for="parent-name" class="block text-sm font-semibold text-gray-700 mb-1.5">Parent / Guardian Name <span class="text-brand-red">*</span></label>
            <input type="text" id="parent-name" name="parent_name" required autocomplete="name"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition-shadow"
              placeholder="Enter parent's full name" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number <span class="text-brand-red">*</span></label>
            <input type="tel" id="phone" name="phone" required autocomplete="tel"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition-shadow"
              placeholder="e.g. 9876543210" />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address</label>
            <input type="email" id="email" name="email" autocomplete="email"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition-shadow"
              placeholder="optional" />
          </div>
        </div>

        <div>
          <label for="class" class="block text-sm font-semibold text-gray-700 mb-1.5">Class Applying For <span class="text-brand-red">*</span></label>
          <select id="class" name="class_applying_for" required
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition-shadow bg-white">
            <option value="" disabled selected>Select class</option>
            {['Nursery', 'LKG', 'UKG', 'Class I', 'Class II', 'Class III', 'Class IV', 'Class V',
              'Class VI', 'Class VII', 'Class VIII', 'Class IX', 'Class X', 'Class XI', 'Class XII'].map(c => (
              <option value={c}>{c}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Message / Questions</label>
          <textarea id="message" name="message" rows="3"
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent transition-shadow resize-none"
            placeholder="Any questions about fees, schedule, transport, etc."></textarea>
        </div>

        <input type="hidden" name="_subject" value="New Admission Enquiry – H.S.R.D Public School" />

        <button type="submit"
          class="w-full bg-brand-yellow hover:bg-yellow-400 text-brand-blue font-bold py-3.5 px-6 rounded-lg transition-all hover:scale-[1.02] text-base shadow-md">
          Submit Enquiry
        </button>
        <p class="text-xs text-gray-400 text-center">We'll respond within 24 hours. Your information is private and will not be shared.</p>
      </form>
    </div>
  </section>
</Layout>
