---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img src="/logo.png" alt="H.S.R.D Public School" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
          <div>
            <p class="text-white font-bold leading-tight">H.S.R.D Public School</p>
            <p class="text-gray-400 text-xs">Lauriya, West Champaran</p>
          </div>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">
          For your child's bright future. Aspiring for excellence since our founding in Lauriya, Bihar.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          {[
            ['Home', '/'],
            ['About Us', '/about'],
            ['Academics', '/academics'],
            ['Admissions', '/admissions'],
            ['Life @ School', '/life'],
            ['Contact', '/contact'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="hover:text-brand-yellow transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>Lauriya, West Champaran, Bihar</span>
          </li>
          <li class="flex gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21L8.5 10.5a11.042 11.042 0 005 5l1.113-1.724a1 1 0 011.21-.502l4.493 1.498A1 1 0 0121 15.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:8210853223" class="hover:text-brand-yellow transition-colors">8210853223</a>
          </li>
          <li class="flex gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:infohsrdgroupofinst53@gmail.com" class="hover:text-brand-yellow transition-colors break-all">
              infohsrdgroupofinst53@gmail.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Admissions CTA -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Admissions 2025–26</h3>
        <p class="text-sm text-gray-400 mb-4">Admissions are open. Enquire today to secure your child's place.</p>
        <a href="/admissions#enquiry-form"
           class="inline-block bg-brand-yellow hover:bg-yellow-400 text-brand-blue font-semibold px-5 py-2.5 rounded transition-colors text-sm">
          Enquire Now
        </a>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>&copy; {year} H.S.R.D Public School, Lauriya. All rights reserved.</p>
      <p>Founder & MD: Ashok Kumar</p>
    </div>
  </div>
</footer>
